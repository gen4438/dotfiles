{{ template "shebang-bash.tmpl" . }}
# Setup development tools after package installation
# This script is refactored to use common libraries
# script hash: {{ include ".chezmoiscripts/run_once_after_20-setup-tools.sh.tmpl" | sha256sum }}

set -e

# Include common libraries
{{ template "lib-logging.sh.tmpl" . }}

log_info "Setting up development tools..."

# Setup fzf
if check_directory "$HOME/.fzf"; then
    log_step "Checking fzf setup..."
    # Check if fzf is already properly installed
    if [[ ! -f "$HOME/.fzf.bash" ]] || [[ ! -f "$HOME/.fzf.zsh" ]]; then
        log_running "Setting up fzf..."
        cd "$HOME/.fzf"
        ./install --all --no-update-rc
        log_success "fzf setup completed"
    else
        log_success "fzf already configured"
    fi
fi

# Setup mise (unified version manager for Python, Node.js, Go, Rust)
{{- if and (ne .chezmoi.os "windows") (ne .chezmoi.os "android") }}
log_step "Setting up mise..."
if check_command mise; then
    log_success "mise is already installed"
else
    log_running "Installing mise..."
    if curl https://mise.run | sh; then
        export PATH="$HOME/.local/bin:$PATH"
        log_success "mise installed successfully"
    else
        log_warning "Failed to install mise"
    fi
fi

# Install default tool versions with mise
if check_command mise; then
    log_step "Installing tool versions via mise..."
    # Trust the global config
    mise trust --all 2>/dev/null || true
    # Install all tools defined in global config
    if mise install; then
        log_success "mise tools installed successfully"
    else
        log_warning "Failed to install some mise tools"
    fi
fi
{{- end }}

# Setup Zim plugins (zsh plugin manager)
{{- $shells := fromJson (includeTemplate "shell-detection.tmpl" .) }}
{{- if $shells.uses_zsh }}
log_step "Setting up Zim plugins..."

if check_command zsh; then
    ZIM_HOME="$HOME/.zim"
    if [[ -f "$ZIM_HOME/zimfw.zsh" ]] || [[ -f "/opt/homebrew/opt/zimfw/share/zimfw.zsh" ]] || [[ -f "/usr/local/opt/zimfw/share/zimfw.zsh" ]]; then
        log_running "Installing Zim modules..."
        zsh -c '
            ZIM_HOME=~/.zim
            {{- if eq .chezmoi.os "darwin" }}
            if [[ -d "/opt/homebrew" ]]; then
                ZIMFW_PATH="/opt/homebrew/opt/zimfw/share/zimfw.zsh"
            else
                ZIMFW_PATH="/usr/local/opt/zimfw/share/zimfw.zsh"
            fi
            if [[ -f "$ZIMFW_PATH" ]]; then
                source "$ZIMFW_PATH" install
            fi
            {{- else }}
            if [[ -f "$ZIM_HOME/zimfw.zsh" ]]; then
                source "$ZIM_HOME/zimfw.zsh" install
            fi
            {{- end }}
        '
        log_success "Zim modules installed"
    else
        log_warning "Zim not found, skipping plugin installation"
    fi
else
    log_warning "zsh not available, skipping Zim plugin installation"
fi
{{- else }}
log_info "zsh not detected, skipping Zim plugin installation"
{{- end }}

# Setup tmux plugin manager
if check_directory "$HOME/.tmux/plugins/tpm"; then
    log_step "Checking tmux plugin manager..."

    # Install tmux plugins if tmux is available
    if check_command tmux; then
        # Check if plugins are already installed by looking for common plugin directories
        if [[ ! -d "$HOME/.tmux/plugins/tmux-sensible" ]] && [[ ! -d "$HOME/.tmux/plugins/tmux-yank" ]]; then
            log_running "Installing tmux plugins..."
            # Set TMUX_PLUGIN_MANAGER_PATH for the install script
            export TMUX_PLUGIN_MANAGER_PATH="$HOME/.tmux/plugins"
            # Run TPM install script
            "$HOME/.tmux/plugins/tpm/bin/install_plugins"
            log_success "tmux plugins installed"
        else
            log_success "tmux plugins already installed"
        fi
    fi
fi

{{- if eq .chezmoi.os "darwin" }}
# macOS specific setup
log_step "Setting up macOS specific tools..."

# Additional macOS-specific tools can be added here
{{- end }}

{{- if eq .chezmoi.os "linux" }}
# Linux specific setup
log_step "Setting up Linux specific tools..."

# Setup direnv if available
if check_command direnv; then
    log_success "direnv is available"
fi
{{- else if eq .chezmoi.os "android" }}
# Android/Termux specific setup
log_step "Setting up Android/Termux specific tools..."

# Termux-specific configurations can be added here
log_success "Termux environment detected"
{{- end }}

{{- if eq .chezmoi.os "windows" }}
# Windows specific setup (PowerShell)
log_step "Setting up Windows specific tools..."

# This will be handled in PowerShell scripts
{{- end }}

# Setup uv (Python package manager)
{{- if and (ne .chezmoi.os "windows") (ne .chezmoi.os "android") }}
log_step "Setting up uv..."
if check_command uv; then
    log_success "uv is already installed"
else
    log_running "Installing uv..."
    if curl -LsSf https://astral.sh/uv/install.sh | sh; then
        # Ensure uv is on PATH for subsequent commands
        export PATH="$HOME/.local/bin:$PATH"
        log_success "uv installed successfully"
    else
        log_warning "Failed to install uv"
    fi
fi

# Install uv tools
if check_command uv; then
    log_step "Installing uv tools..."
    for tool in ruff ipython; do
        if uv tool list 2>/dev/null | grep -q "^${tool} "; then
            log_success "${tool} is already installed"
        else
            log_running "Installing ${tool}..."
            if uv tool install "${tool}"; then
                log_success "${tool} installed successfully"
            else
                log_warning "Failed to install ${tool}"
            fi
        fi
    done
fi
{{- end }}

# Setup devcontainer CLI
{{- if ne .chezmoi.os "windows" }}
log_step "Setting up devcontainer CLI..."
if check_command devcontainer; then
    log_success "devcontainer CLI is already installed"
else
    log_running "Installing devcontainer CLI..."
    if check_command npm; then
        if npm install -g @devcontainers/cli; then
            log_success "devcontainer CLI installed successfully"
        else
            log_warning "Failed to install devcontainer CLI via npm"
        fi
    elif check_command node; then
        # Try npx as fallback
        log_warning "npm not found, devcontainer CLI not installed (install Node.js/npm first)"
    else
        log_warning "Node.js not found, skipping devcontainer CLI installation"
    fi
fi
{{- end }}

# Setup Claude Code
{{- if ne .chezmoi.os "windows" }}
log_step "Setting up Claude Code..."
if check_command claude; then
    log_success "Claude Code is already installed"
else
    log_running "Installing Claude Code..."
    if curl -fsSL https://claude.ai/install.sh | bash; then
        log_success "Claude Code installed successfully"
    else
        log_warning "Failed to install Claude Code"
    fi
fi
{{- end }}

log_success "Development tools setup completed"
