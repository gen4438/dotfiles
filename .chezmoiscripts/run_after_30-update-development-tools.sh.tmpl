{{ template "shebang-bash.tmpl" . }}
# Update development tools and runtimes
# This script runs on every chezmoi apply to keep tools up-to-date
# Git repositories are automatically updated by chezmoi external management

set -e

# Include common libraries
{{ template "lib-logging.sh.tmpl" . }}

log_info "Updating development tools..."

# Note: External git repositories (.fzf, etc.) are automatically
# updated by chezmoi external with refreshPeriod = "168h" (weekly)
log_info "External repositories are managed by chezmoi and updated weekly"

# Update mise and tool versions
{{- if and (ne .chezmoi.os "android") (ne .chezmoi.os "windows") }}
log_step "Updating mise tools..."

if check_command mise; then
    # Upgrade mise itself
    if mise self-update --yes 2>/dev/null; then
        log_success "mise updated"
    else
        log_info "mise self-update not available (installed via package manager)"
    fi

    # Install/upgrade all configured tools
    if mise install; then
        log_success "mise tools are up to date"
    else
        log_warning "Failed to update some mise tools"
    fi

    # Upgrade installed tool versions
    if mise upgrade --yes 2>/dev/null; then
        log_success "mise tool versions upgraded"
    else
        log_info "No tool upgrades available"
    fi

    # Setup Neovim Python provider using uv
    log_step "Setting up Neovim Python provider..."
    NVIM_VENV_DIR="$HOME/.local/share/nvim-venv"
    if [[ ! -d "$NVIM_VENV_DIR" ]]; then
        log_running "Creating Neovim Python virtual environment..."
        if check_command uv; then
            uv venv "$NVIM_VENV_DIR"
            uv pip install --python "$NVIM_VENV_DIR/bin/python" pynvim neovim
            log_success "Neovim Python provider installed via uv"
        elif check_command python3; then
            python3 -m venv "$NVIM_VENV_DIR"
            "$NVIM_VENV_DIR/bin/pip" install --upgrade pip pynvim neovim
            log_success "Neovim Python provider installed via venv"
        else
            log_warning "Neither uv nor python3 available for Neovim provider"
        fi
    else
        log_running "Updating Neovim Python packages..."
        if check_command uv; then
            uv pip install --python "$NVIM_VENV_DIR/bin/python" --upgrade pynvim neovim
        else
            "$NVIM_VENV_DIR/bin/pip" install --upgrade pynvim neovim
        fi
        log_success "Neovim Python provider updated"
    fi

    # Ensure Neovim Node.js package is installed
    if check_command npm; then
        if ! npm list -g neovim >/dev/null 2>&1; then
            log_running "Installing Neovim Node.js package..."
            if npm install -g neovim; then
                log_success "Neovim Node.js package installed"
            else
                log_warning "Failed to install Neovim Node.js package"
            fi
        else
            log_success "Neovim Node.js package is installed"
        fi
    fi
else
    log_warning "mise not available, skipping tool updates"
fi
{{- else if eq .chezmoi.os "android" }}
log_info "Android/Termux: Using system Python (pkg install python)"
log_info "Android/Termux: Using system Node.js (pkg install nodejs)"
log_step "Installing Neovim packages globally..."

# For Termux, install packages globally
if check_command pip; then
    pip install --upgrade --user pynvim neovim
    log_success "Python packages for Neovim installed"
fi

if check_command npm; then
    npm install -g neovim
    log_success "Node.js package for Neovim installed"
fi
{{- end }}

log_success "Development tools update completed"
