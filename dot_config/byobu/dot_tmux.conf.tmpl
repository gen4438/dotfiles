{{- if and (eq .chezmoi.os "linux") (contains "microsoft" .chezmoi.kernel.osrelease) }}
# WSL2: シェルディスパッチャー経由で起動 (@byobu-shell で切り替え)
# 初期値は環境変数 BYOBU_SHELL から取得 (未設定時は pwsh)
# ~/.env に BYOBU_SHELL=bash 等と書くことで変更可能
set-option -g default-command '~/.config/byobu/bin/powershell-wrapper.sh'
run-shell 'tmux set-option -g @byobu-shell "${BYOBU_SHELL:-pwsh}"'
{{- end }}

set-option -g default-terminal tmux-256color
set -g unicode-ambiguous wide
# set-option -g default-terminal screen-256color
set-option -ga terminal-overrides ",*256*:Tc"
# set -g mouse on

set-option -s set-clipboard on
set -g set-clipboard on

# # ペインボーダーの色を設定する
# set -g pane-border-fg black
# set -g pane-border-bg default

# # アクティブなペインを目立たせる
# set -g pane-active-border-fg blue
# set -g pane-active-border-bg default

# # Git の情報を表示
set -g status-right '#(gitmux -cfg ~/.config/byobu/.gitmux.conf "#{pane_current_path}")'
set -g status-right-length 200

# # 元の表示（全システム情報付き）
# set -g status-right '#(gitmux -cfg ~/.config/byobu/.gitmux.conf "#{pane_current_path}") #(byobu-status tmux_right)'
# set -g status-right-length 200

# byobo と一緒に使う場合の設定
# https://github.com/tmux-plugins/tpm/blob/master/docs/tpm_not_working.md
# List of plugins
set -g @tpm_plugins '          \
  tmux-plugins/tpm             \
  tmux-plugins/tmux-sensible   \
  tmux-plugins/tmux-resurrect  \
  tmux-plugins/tmux-continuum  \
'

set -sa terminal-features 'xterm*:clipboard'

if-shell 'tmux -V | awk "{split(\$2,v,/[.]/); if(v[1]>3||(v[1]==3&&v[2]>=3))exit 0; else exit 1}"' \
  'set -s allow-passthrough on'

# vi mode for copy mode
setw -g mode-keys vi
bind -T copy-mode-vi v send -X begin-selection
bind -T copy-mode-vi y send -X copy-pipe-and-cancel '~/.config/byobu/osc52-copy'
# bind -T copy-mode-vi Enter send -X copy-pipe-and-cancel '~/.config/byobu/osc52-copy'

# set -g @plugin 'tmux-plugins/tpm'
# # List of plugins
# set -g @plugin 'tmux-plugins/tmux-sensible'
# set -g @plugin 'tmux-plugins/tmux-resurrect'
# set -g @plugin 'tmux-plugins/tmux-continuum'

# resurrect
set -g @resurrect-processes 'false'
# set -g @resurrect-strategy-vim 'session'
# set -g @resurrect-strategy-nvim 'session'
# set -g @resurrect-capture-pane-contents 'on'

# continuum
# set -g @continuum-restore 'on'

# Initialize TMUX plugin manager
run '~/.tmux/plugins/tpm/tpm'
{{- if and (eq .chezmoi.os "linux") (contains "microsoft" .chezmoi.kernel.osrelease) }}

# WSL2: tpm/tmux-sensible の後に配置し、組み込みキーバインドを確実に上書きする

# デフォルトシェルをトグル (pwsh → bash → powershell → pwsh ...)
bind-key t run-shell '\
    current=$(tmux show-option -gqv @byobu-shell); \
    case "$current" in \
        pwsh)       next=bash;       label="bash" ;; \
        bash)       next=powershell; label="powershell.exe" ;; \
        powershell) next=pwsh;       label="pwsh.exe" ;; \
        *)          next=pwsh;       label="pwsh.exe" ;; \
    esac; \
    tmux set-option -g @byobu-shell "$next"; \
    tmux display-message "Default shell: $label"'

# 明示的にシェルを指定して開く
bind-key b new-window -n bash bash
bind-key B split-window -h bash
bind-key p new-window -n pwsh '~/.config/byobu/bin/powershell-wrapper.sh'
{{- end }}
